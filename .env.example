# PostHog analytics — public client-side keys, safe to commit.
VITE_PUBLIC_POSTHOG_KEY=phc_replace_with_your_project_token
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Public Stripe Payment Link. Never put a Stripe secret key in VITE_* variables.
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-payment-link

# Public key used by the optional Vercel Checkout donation flow.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key

# Optional override for the GitHub Sponsors page.
VITE_GITHUB_SPONSORS_URL=https://github.com/sponsors/armandfardeau

# Optional open-source donation page (Open Collective, Ko-fi, Liberapay, etc.).
VITE_DONATION_URL=https://opencollective.com/your-project

# Server-only Vercel variables for the optional Checkout donation flow.
# STRIPE_SECRET_KEY=sk_live_your_rotated_secret_key
# STRIPE_CURRENCY=usd
# APP_URL=https://your-vercel-domain.vercel.app
